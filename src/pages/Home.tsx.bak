import { useEffect, useState, useMemo } from 'react';
import { useNavigate } from 'react-router-dom';
import { ShoppingBag } from 'lucide-react';
import { productsApi, type Product } from '../lib/api';
import { useCart } from '../hooks/useCart';
import { toast } from 'sonner';

export default function HomePage() {
  const navigate = useNavigate();
  const { addItem } = useCart();

  const [products, setProducts] = useState<Product[]>([]);
  const [loading, setLoading] = useState(true);

  // ✅ SAFE FETCH (anti memory leak)
  useEffect(() => {
    let mounted = true;

    productsApi.list()
      .then(r => {
        if (mounted) setProducts(r.products);
      })
      .catch(() => {})
      .finally(() => {
        if (mounted) setLoading(false);
      });

    return () => { mounted = false };
  }, []);

  // 🔥 PRODUITS POPULAIRES
  const popularProducts = useMemo(() => products.slice(0, 10), [products]);

  // 🧠 RECOMMANDATIONS
  const recommendedProducts = useMemo(() => products.slice(5, 15), [products]);

  const handleAdd = (p: Product, e: React.MouseEvent) => {
    e.stopPropagation();

    addItem({
      id: p.id,
      name: p.name,
      price: parseFloat(p.price as any),
      image: p.image,
      quantity: 1
    });

    toast.success(`${p.name} ajouté au panier`);
  };

  return (
    <div className="bg-[#f5f5f5] min-h-screen">

      {/* HERO SIMPLIFIÉ (FOCUS PRODUITS) */}
      <section className="bg-[#0d1117] text-white py-10 px-4">
        <div className="max-w-[1400px] mx-auto flex flex-col md:flex-row items-center justify-between gap-6">

          <div>
            <h1 className="text-3xl md:text-4xl font-black leading-tight">
              Luxesensuel 🔥
            </h1>
            <p className="text-white/60 mt-2 text-sm max-w-md">
              Découvrez des produits tendances à prix réduit avec livraison internationale.
            </p>

            <button
              onClick={() => navigate('/shop')}
              className="mt-4 px-6 py-3 bg-orange-500 rounded-lg font-bold text-sm hover:bg-orange-600"
            >
              Voir la boutique
            </button>
          </div>

          {/* MINI STATS */}
          <div className="grid grid-cols-2 gap-3 text-center">
            <div className="bg-[#1a2035] p-4 rounded-lg">
              <p className="text-xs text-white/50">Produits</p>
              <p className="text-lg font-bold">{products.length}</p>
            </div>
            <div className="bg-[#1a2035] p-4 rounded-lg">
              <p className="text-xs text-white/50">Commandes</p>
              <p className="text-lg font-bold">+1200</p>
            </div>
          </div>

        </div>
      </section>

      {/* 🔥 PRODUITS POPULAIRES */}
      <section className="py-6 px-4">
        <div className="max-w-[1400px] mx-auto">

          <div className="flex justify-between items-center mb-4">
            <h2 className="text-lg font-bold">🔥 Produits populaires</h2>
            <button onClick={() => navigate('/shop')} className="text-orange-500 text-sm">
              Voir tout
            </button>
          </div>

          {loading ? (
            <div className="grid grid-cols-2 md:grid-cols-5 gap-3">
              {[...Array(10)].map((_, i) => (
                <div key={i} className="bg-white h-60 rounded-lg animate-pulse" />
              ))}
            </div>
          ) : (
            <div className="grid grid-cols-2 md:grid-cols-5 gap-3">
              {popularProducts.map(p => {
                const price = parseFloat(p.price as any);
                const oldPrice = price * 1.4;
                const discount = Math.round(((oldPrice - price) / oldPrice) * 100);

                return (
                  <div
                    key={p.id}
                    onClick={() => navigate(`/product/${p.id}`)}
                    className="bg-white rounded-lg border hover:shadow-md transition cursor-pointer"
                  >
                    <div className="relative">
                      <img src={p.image} className="w-full h-40 object-cover" />

                      {/* PROMO */}
                      <span className="absolute top-2 left-2 bg-red-500 text-white text-xs px-2 py-1 rounded">
                        -{discount}%
                      </span>
                    </div>

                    <div className="p-2">

                      <p className="text-xs line-clamp-2 h-8">{p.name}</p>

                      {/* RATING */}
                      <div className="text-yellow-500 text-xs">
                        ⭐⭐⭐⭐☆ <span className="text-gray-400">(120)</span>
                      </div>

                      <p className="text-[10px] text-gray-400">
                        500+ vendus
                      </p>

                      <div className="flex items-center gap-2">
                        <span className="text-red-500 font-bold text-sm">
                          {price.toFixed(2)}€
                        </span>
                        <span className="text-gray-400 text-xs line-through">
                          {oldPrice.toFixed(2)}€
                        </span>
                      </div>

                      <button
                        onClick={(e) => handleAdd(p, e)}
                        className="mt-2 w-full bg-orange-500 text-white text-xs py-1 rounded hover:bg-orange-600"
                      >
                        <ShoppingBag size={14} />
                      </button>

                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </section>

      {/* 🧠 RECOMMANDATIONS */}
      <section className="py-6 px-4 bg-white">
        <div className="max-w-[1400px] mx-auto">

          <h2 className="text-lg font-bold mb-4">
            🧠 Tu pourrais aussi aimer
          </h2>

          <div className="flex gap-3 overflow-x-auto">
            {recommendedProducts.map(p => (
              <div
                key={p.id}
                onClick={() => navigate(`/product/${p.id}`)}
                className="min-w-[140px] bg-gray-50 rounded-lg p-2 cursor-pointer"
              >
                <img src={p.image} className="h-24 w-full object-cover rounded" />
                <p className="text-xs mt-1 line-clamp-2">{p.name}</p>
                <p className="text-red-500 text-sm font-bold">
                  {parseFloat(p.price as any).toFixed(2)}€
                </p>
              </div>
            ))}
          </div>

        </div>
      </section>

      {/* CTA */}
      <section className="py-10 text-center">
        <button
          onClick={() => navigate('/shop')}
          className="px-6 py-3 bg-orange-500 text-white rounded-lg font-bold hover:bg-orange-600"
        >
          Explorer tous les produits
        </button>
      </section>

    </div>
  );
}