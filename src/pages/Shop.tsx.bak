import { useEffect, useMemo, useState, useCallback } from 'react';
import { useNavigate, useSearchParams } from 'react-router-dom';
import { Search, ShoppingBag, Star, Package, ChevronDown, Grid3X3, LayoutList, Heart } from 'lucide-react';
import { productsApi, type Product } from '../lib/api';
import { useCart } from '../hooks/useCart';
import { toast } from 'sonner';

const stripHtml = (html: string) => html?.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim() || '';
const CATEGORIES = ['TOUS','LINGERIE','PARFUMS','HUILES','ENSEMBLES','ACCESSOIRES','SOINS','COFFRETS','COUPLES'];
const SORTS = [{ label: 'Nouveautés', value: 'new' },{ label: 'Prix croissant', value: 'price_asc' },{ label: 'Prix décroissant', value: 'price_desc' }];
const PRICE_RANGES = [{ label: 'Tous les prix', min: 0, max: Infinity },{ label: 'Moins de 20€', min: 0, max: 20 },{ label: '20€ – 50€', min: 20, max: 50 },{ label: '50€ – 100€', min: 50, max: 100 },{ label: 'Plus de 100€', min: 100, max: Infinity }];

export default function Shop() {
  const navigate = useNavigate();
  const [searchParams, setSearchParams] = useSearchParams();
  const { addItem } = useCart();
  const [products, setProducts] = useState<Product[]>([]);
  const [loading, setLoading] = useState(true);
  const [view, setView] = useState<'grid'|'list'>('grid');
  const [search, setSearch] = useState('');
  const [searchInput, setSearchInput] = useState('');
  const [activeCategory, setActiveCategory] = useState(searchParams.get('category')?.toUpperCase() || 'TOUS');
  const [sort, setSort] = useState('new');
  const [priceRange, setPriceRange] = useState(0);
  const [wishlist, setWishlist] = useState<Set<string>>(new Set());
  const [page, setPage] = useState(1);
  const PER = 20;

  const loadProducts = useCallback(async () => {
    setLoading(true);
    try {
      const params: any = {};
      if (activeCategory !== 'TOUS') params.category = activeCategory.charAt(0) + activeCategory.slice(1).toLowerCase();
      if (search) params.search = search;
      const data = await productsApi.list(params);
      setProducts(data.products); setPage(1);
    } catch { toast.error('Erreur chargement'); }
    finally { setLoading(false); }
  }, [activeCategory, search]);

  useEffect(() => { loadProducts(); }, [loadProducts]);

  const filtered = useMemo(() => {
    const r = PRICE_RANGES[priceRange];
    let list = products.filter(p => { const pr = parseFloat(p.price as any); return pr >= r.min && pr <= r.max; });
    if (sort === 'price_asc') list = [...list].sort((a,b) => parseFloat(a.price as any) - parseFloat(b.price as any));
    if (sort === 'price_desc') list = [...list].sort((a,b) => parseFloat(b.price as any) - parseFloat(a.price as any));
    return list;
  }, [products, priceRange, sort]);

  const paginated = useMemo(() => filtered.slice(0, page * PER), [filtered, page]);

  const handleAdd = (p: Product, e: React.MouseEvent) => {
    e.stopPropagation();
    if (p.stock === 0) { toast.error('Épuisé'); return; }
    addItem({ id: p.id, name: p.name, price: parseFloat(p.price as any), image: p.image, quantity: 1 });
    toast.success(`${p.name} ajouté`);
  };

  const toggleWishlist = (id: string, e: React.MouseEvent) => {
    e.stopPropagation();
    setWishlist(prev => { const n = new Set(prev); n.has(id) ? n.delete(id) : n.add(id); return n; });
  };

  const setCategory = (cat: string) => {
    setActiveCategory(cat);
    cat !== 'TOUS' ? setSearchParams({ category: cat.toLowerCase() }) : setSearchParams({});
  };

  return (
    <div className="min-h-screen bg-[#fafafa]" style={{ fontFamily: "'Outfit','DM Sans',sans-serif" }}>
      {/* Header */}
      <div className="bg-white border-b border-gray-100 px-6 py-8">
        <div className="max-w-7xl mx-auto">
          <h1 className="text-4xl font-black text-[#0d1117] mb-1">Nos produits</h1>
          <p className="text-gray-400 mb-6">Large gamme de produits sélectionnés de qualité provenant d'AliExpress et CJ</p>
          <form onSubmit={e => { e.preventDefault(); setSearch(searchInput); }} className="flex gap-3 max-w-2xl mb-6">
            <div className="relative flex-1">
              <Search size={15} className="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400" />
              <input value={searchInput} onChange={e => setSearchInput(e.target.value)} placeholder="Rechercher un produit..."
                className="w-full border border-gray-200 rounded-xl py-3 pl-11 pr-4 text-sm text-gray-700 outline-none focus:border-orange-400 bg-white" />
            </div>
            <button type="submit" style={{ backgroundColor: '#E07820' }} className="px-6 py-3 rounded-xl text-white font-bold text-sm uppercase tracking-wider hover:opacity-90 transition-opacity">CHERCHER</button>
          </form>
          <div className="flex flex-wrap gap-2">
            {CATEGORIES.map(cat => (
              <button key={cat} onClick={() => setCategory(cat)} className="px-5 py-2.5 rounded-full font-semibold text-sm transition-all"
                style={activeCategory === cat ? { backgroundColor: '#E07820', color: 'white' } : { backgroundColor: '#f0f0f0', color: '#555' }}>
                {cat}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div className="max-w-7xl mx-auto px-6 py-6 flex gap-6">
        {/* Sidebar */}
        <aside className="w-52 flex-shrink-0 hidden lg:block">
          <div className="bg-white rounded-2xl border border-gray-100 p-5 sticky top-6">
            <h3 className="font-bold text-[#0d1117] text-xs uppercase tracking-widest mb-3">BUDGET</h3>
            <div className="space-y-1 mb-5">
              {PRICE_RANGES.map((r, i) => (
                <button key={i} onClick={() => setPriceRange(i)} className="w-full text-left px-3 py-2 rounded-xl text-sm transition-all"
                  style={priceRange === i ? { backgroundColor: '#E0782015', color: '#E07820', fontWeight: 600 } : { color: '#777' }}>
                  {r.label}
                </button>
              ))}
            </div>
            <h3 className="font-bold text-[#0d1117] text-xs uppercase tracking-widest mb-3">TRIER PAR</h3>
            <div className="space-y-1 mb-5">
              {SORTS.map(s => (
                <button key={s.value} onClick={() => setSort(s.value)} className="w-full text-left px-3 py-2 rounded-xl text-sm transition-all"
                  style={sort === s.value ? { backgroundColor: '#E0782015', color: '#E07820', fontWeight: 600 } : { color: '#777' }}>
                  {s.label}
                </button>
              ))}
            </div>
            <button onClick={() => { setActiveCategory('TOUS'); setPriceRange(0); setSort('new'); setSearch(''); setSearchInput(''); setSearchParams({}); }}
              className="w-full py-2 text-sm text-gray-400 hover:text-gray-600 border border-gray-200 rounded-xl transition-colors">
              Réinitialiser
            </button>
          </div>
        </aside>

        {/* Grille */}
        <div className="flex-1 min-w-0">
          <div className="flex items-center justify-between mb-5">
            <span className="text-sm text-gray-400">{filtered.length} produit(s)</span>
            <div className="flex gap-1">
              <button onClick={() => setView('grid')} className="p-2 rounded-lg transition-colors" style={view === 'grid' ? { backgroundColor: '#E0782015', color: '#E07820' } : { color: '#aaa' }}><Grid3X3 size={15}/></button>
              <button onClick={() => setView('list')} className="p-2 rounded-lg transition-colors" style={view === 'list' ? { backgroundColor: '#E0782015', color: '#E07820' } : { color: '#aaa' }}><LayoutList size={15}/></button>
            </div>
          </div>

          {loading ? (
            <div className="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4">
              {[...Array(8)].map((_,i) => <div key={i} className="bg-gray-100 rounded-2xl h-72 animate-pulse"/>)}
            </div>
          ) : filtered.length === 0 ? (
            <div className="py-24 text-center"><Package size={48} className="mx-auto text-gray-200 mb-4"/><p className="text-gray-400">Aucun produit trouvé</p></div>
          ) : view === 'grid' ? (
            <>
              <div className="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4">
                {paginated.map(p => {
                  const price = parseFloat(p.price as any);
                  return (
                    <div key={p.id} onClick={() => navigate(`/product/${p.id}`)}
                      className="bg-white border border-gray-100 rounded-2xl overflow-hidden hover:shadow-md transition-all cursor-pointer group">
                      <div className="relative aspect-square overflow-hidden bg-gray-50">
                        {p.image ? <img src={p.image} alt={p.name} className="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"/>
                          : <div className="w-full h-full flex items-center justify-center"><Package size={36} className="text-gray-200"/></div>}
                        {p.is_new && <span className="absolute top-2 left-2 text-[9px] font-black px-2 py-1 rounded-lg uppercase text-white" style={{ backgroundColor: '#E07820' }}>NOUVEAU</span>}
                        {p.stock === 0 && <div className="absolute inset-0 bg-white/70 flex items-center justify-center"><span className="text-sm font-bold text-gray-500">Épuisé</span></div>}
                        <button onClick={e => toggleWishlist(p.id, e)} className="absolute top-2 right-2 w-7 h-7 rounded-xl bg-white shadow flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                          <Heart size={12} className={wishlist.has(p.id) ? 'fill-red-500 text-red-500' : 'text-gray-400'}/>
                        </button>
                      </div>
                      <div className="p-3">
                        <p className="text-[9px] uppercase tracking-widest font-bold mb-1" style={{ color: '#E07820' }}>{p.category}</p>
                        <h3 className="text-xs font-semibold text-[#0d1117] line-clamp-2 mb-2">{p.name}</h3>
                        <div className="flex items-center gap-1 mb-2">
                          {[1,2,3,4,5].map(i => <Star key={i} size={9} className={i<=4 ? 'fill-yellow-400 text-yellow-400' : 'text-gray-200'}/>)}
                        </div>
                        <div className="flex items-center justify-between">
                          <span className="font-black text-sm" style={{ color: '#E07820' }}>{price.toFixed(2)} €</span>
                          <button onClick={e => handleAdd(p, e)} disabled={p.stock === 0} style={{ backgroundColor: '#E07820' }}
                            className="w-7 h-7 rounded-lg flex items-center justify-center text-white disabled:opacity-30 hover:opacity-80 transition-opacity">
                            <ShoppingBag size={11}/>
                          </button>
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
              {paginated.length < filtered.length && (
                <div className="flex justify-center mt-10">
                  <button onClick={() => setPage(p => p+1)} style={{ borderColor: '#E07820', color: '#E07820' }}
                    className="flex items-center gap-2 px-8 py-3 rounded-xl border-2 font-semibold text-sm hover:bg-orange-50 transition-colors">
                    <ChevronDown size={15}/> Charger plus ({filtered.length - paginated.length})
                  </button>
                </div>
              )}
            </>
          ) : (
            <div className="space-y-3">
              {paginated.map(p => {
                const price = parseFloat(p.price as any);
                return (
                  <div key={p.id} onClick={() => navigate(`/product/${p.id}`)}
                    className="bg-white border border-gray-100 rounded-2xl flex gap-4 p-4 hover:shadow-md transition-all cursor-pointer">
                    <div className="w-20 h-20 flex-shrink-0 rounded-xl overflow-hidden bg-gray-50">
                      {p.image ? <img src={p.image} alt={p.name} className="w-full h-full object-cover"/> : <div className="w-full h-full flex items-center justify-center"><Package size={20} className="text-gray-200"/></div>}
                    </div>
                    <div className="flex-1 min-w-0 flex flex-col justify-between">
                      <div>
                        <p className="text-[9px] uppercase tracking-widest font-bold mb-0.5" style={{ color: '#E07820' }}>{p.category}</p>
                        <h3 className="font-semibold text-[#0d1117] text-sm line-clamp-1">{p.name}</h3>
                        <p className="text-gray-400 text-xs mt-1 line-clamp-1">{stripHtml(p.description)}</p>
                      </div>
                      <div className="flex items-center justify-between">
                        <span className="font-black text-base" style={{ color: '#E07820' }}>{price.toFixed(2)} €</span>
                        <button onClick={e => handleAdd(p, e)} disabled={p.stock === 0} style={{ backgroundColor: '#E07820' }}
                          className="flex items-center gap-1 px-3 py-2 rounded-xl text-white text-xs font-semibold disabled:opacity-30 hover:opacity-80 transition-opacity">
                          <ShoppingBag size={11}/> Ajouter
                        </button>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
